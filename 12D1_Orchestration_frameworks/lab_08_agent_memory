# lab8_agent_memory.py
import os
from dotenv import load_dotenv
from langchain_openai import ChatOpenAI
from langchain.agents import create_agent
from langchain_core.tools import tool
from langchain_core.messages import HumanMessage, AIMessage

load_dotenv()

@tool
def get_clinic_stock_count(medication_name: str) -> str:
    """Returns current stock for a medication at the AfyaPlus clinic."""
    stock = {"amoxicillin": 120, "paracetamol": 540}
    return f"{stock.get(medication_name.lower(), 0)} units"

llm = ChatOpenAI(model="gpt-4o-mini", temperature=0.0)
tools = [get_clinic_stock_count]

agent = create_agent(model=llm, tools=tools)

# Manual memory: store messages for the session
history = []

def chat(user_input):
    history.append(HumanMessage(content=user_input))
    result = agent.invoke({"messages": history})
    ai_response = result["messages"][-1].content
    history.append(AIMessage(content=ai_response))
    return ai_response

# ---- Multi-turn test ----
print("=== Turn 1 ===")
print(chat("My name is Achieng."))

print("\n=== Turn 2 ===")
print(chat("What is my name, and do we have amoxicillin?"))